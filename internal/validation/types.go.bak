// internal/validation/types.go
/*

Check Algorithm:
1. Quick Check (Default):
   - File size
   - Modification time (mtime)
   - File type/mode
   If any mismatch → Proceed to Standard Check

2. Standard Check (On Quick mismatch):
   - First 32KB hash comparison
   - Efficient for catching most changes
   If critical file → Proceed to Deep Check

3. Deep Check (Critical files only):
   - Full file hash comparison
   - Reserved for specifically marked critical files
2-4. Metadat

*/
package validation

import (
	"errors"
	"fmt"
	"time"

	"github.com/jack-sneddon/backup-butler/internal/scan"
)

// ValidationLevel defines how thorough the validation should be
type ValidationLevel string

const (
	Quick    ValidationLevel = "quick"    // Metadata only
	Standard ValidationLevel = "standard" // Partial content hash
	Deep     ValidationLevel = "deep"     // Full content validation
)

// Error definitions
var (
	ErrInvalidValidationLevel = errors.New("invalid validation level")
	ErrInvalidHashAlgorithm  = errors.New("invalid hash algorithm")
	ErrInvalidBufferSize     = errors.New("invalid buffer size")
)

// ValidationStatus represents the result of a validation
type ValidationStatus int

const (
	StatusMatch ValidationStatus = iota
	StatusDiffer
	StatusError
)

// ValidationResult contains the outcome of a validation operation
type ValidationResult struct {
	Status    ValidationStatus
	Message   string
	TimeTaken time.Duration
	BytesRead int64
}

// ValidatorOptions contains configuration for validators
type ValidatorOptions struct {
	BufferSize int    // Size of read buffer for content validation
	Algorithm  string // Hash algorithm (e.g., "sha256")
}

// Validation constants
const (
	MinBufferSize = 4096     // 4KB minimum
	MaxBufferSize = 10485760 // 10MB maximum
)

// Supported hash algorithms
var SupportedAlgorithms = map[string]bool{
	"md5":    true,
	"sha1":   true,
	"sha256": true,
}

func (opts *ValidatorOptions) Validate() error {
	if opts.BufferSize < MinBufferSize || opts.BufferSize > MaxBufferSize {
		return fmt.Errorf("%w: buffer size must be between %d and %d bytes", 
			ErrInvalidBufferSize, MinBufferSize, MaxBufferSize)
	}

	if !SupportedAlgorithms[opts.Algorithm] {
		return fmt.Errorf("%w: must be one of: md5, sha1, sha256", 
			ErrInvalidHashAlgorithm)
	}

	return nil
}

// Validator defines the interface for file validation strategies
type Validator interface {
	// Validate compares source and target files according to the validation strategy
	Validate(source, target *scan.FileInfo) ValidationResult

	// Level returns the validation level this validator implements
	Level() ValidationLevel

	// BufferSize returns the configured buffer size for content validation
	BufferSize() int
}

// ValidatorFactory creates appropriate validators based on the validation level
type ValidatorFactory interface {
	NewValidator(level ValidationLevel, opts *ValidatorOptions) (Validator, error)
}

// DefaultValidatorFactory is the standard implementation of ValidatorFactory
type DefaultValidatorFactory struct{}

func NewValidatorFactory() ValidatorFactory {
	return &DefaultValidatorFactory{}
}

func (f *DefaultValidatorFactory) NewValidator(level ValidationLevel, opts *ValidatorOptions) (Validator, error) {
	switch level {
	case Quick:
		return NewQuickValidator(), nil
	case Standard:
		return NewStandardValidator(opts), nil
	case Deep:
		return NewDeepValidator(opts), nil
	default:
		return nil, ErrInvalidValidationLevel
	}
}